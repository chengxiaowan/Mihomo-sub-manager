generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model SubscriptionSource {
  id              String      @id @default(cuid())
  name            String
  url             String
  enabled         Boolean     @default(true)
  refreshInterval Int?        // 自动更新间隔（分钟），null/0 = 关闭
  excludeKeywords String      @default("[]") // 节点名排除关键字（JSON 字符串数组）
  lastFetchedAt   DateTime?
  fetchStatus     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  nodes           ProxyNode[]
}

model ProxyNode {
  id        String              @id @default(cuid())
  name      String
  type      String
  server    String
  port      Int?
  raw       Json
  enabled   Boolean             @default(true)
  tags      String              @default("[]")
  sourceId  String?
  createdAt DateTime            @default(now())
  source    SubscriptionSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  groups    ProxyGroup[]
}

model ProxyGroup {
  id        String      @id @default(cuid())
  name      String
  type      String
  enabled   Boolean     @default(true)
  sort      Int         @default(0)
  url       String?     // 测速地址（url-test/fallback/load-balance）
  interval  Int?        // 测速间隔（秒）
  tolerance Int?        // 容差（毫秒，仅 url-test）
  lazy      Boolean?    // 惰性测速（仅使用时测）
  filter    String?     // 正则过滤代理
  nodes     ProxyNode[]
  profiles  Profile[]
}

model ProfileRule {
  id        String   @id @default(cuid())
  type      String
  value     String?
  policy    String
  sort      Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Profile {
  id            String         @id @default(cuid())
  name          String
  token         String         @unique
  enabled       Boolean        @default(true)
  defaultPolicy String         @default("DIRECT")
  baseConfig    Json?
  createdAt     DateTime       @default(now())
  groups        ProxyGroup[]
  rules         ProfileRule[]
  providers     RuleProvider[]
}

model RuleProvider {
  id        String    @id @default(cuid())
  name      String    @unique // 引用名，用于 RULE-SET,<name>,<policy>
  type      String // http | file | inline
  behavior  String // domain | ipcidr | classical
  format    String    @default("yaml") // yaml | text | mrs
  url       String? // http 时必填
  path      String? // 缓存/本地路径，http 不填则生成器默认 ./ruleset/<name>.yaml
  interval  Int? // 秒，http 更新间隔
  proxy     String? // 经由某代理组下载
  payload   String    @default("[]") // inline 规则数组（JSON 字符串）
  enabled   Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  profiles  Profile[]
}

model RuleTemplate {
  id          String             @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  items       RuleTemplateItem[]
}

model RuleTemplateItem {
  id         String       @id @default(cuid())
  type       String
  value      String?
  sort       Int          @default(0)
  templateId String
  template   RuleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model OperationLog {
  id         String   @id @default(cuid())
  action     String
  entityType String?
  entityId   String?
  status     String
  message    String?
  detail     Json?
  createdAt  DateTime @default(now())
}
